# UAT Environment Configuration

# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your-secure-password-here
MONGO_DATABASE=oms

# MongoDB Connection URI (for backend)
# Using the containerized MongoDB
MONGODB_URI=mongodb://admin:your-secure-password-here@mongodb:27017/oms?authSource=admin

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-minimum-32-characters
JWT_EXPIRATION=24h

# AI API Keys (Optional - if using AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Backend Configuration
BACKEND_URL=http://backend:3000

# CORS Configuration
CORS_ORIGIN=http://your-uat-domain.com

# Node Environment
NODE_ENV=uat
