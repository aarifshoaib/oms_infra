# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-strong-password
MONGO_DATABASE=oms
MONGODB_URI=mongodb://admin:change-me-strong-password@mongodb:27017/oms?authSource=admin

# JWT
JWT_SECRET=change-me-minimum-32-characters-long!!
JWT_EXPIRATION=24h

# CORS — UAT frontend URL
FRONTEND_URL=http://your-uat-server-ip:8081

# AI (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
