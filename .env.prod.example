# Production Environment Configuration

# MongoDB Connection URI (External MongoDB - MongoDB Atlas or separate server)
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/oms?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-production-jwt-secret-key-here-minimum-32-characters-very-secure
JWT_EXPIRATION=24h

# AI API Keys (Optional - if using AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Backend Configuration
BACKEND_URL=http://backend:3000

# CORS Configuration
CORS_ORIGIN=https://your-production-domain.com

# Node Environment
NODE_ENV=production
